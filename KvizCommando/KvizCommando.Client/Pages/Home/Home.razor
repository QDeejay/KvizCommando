@page "/home"


<LangGuard Culture=@culture Module="home" OnReady="BuildButtons">
    <PageContainer>
        
            @if (_isReady == true)
            {
            <div class="home-selector">
                    @foreach (string bx in BtnOrder)
                    {
                        var box = Box(bx);
                            <ContentBox Header="@box.Header"
                                        Footer="@box.Footer"
                                        FooterDisplay="@box.FooterDisplay"
                                        Size="@(box.ReSizable ? bboardSize : box.Size)"
                                        Resizable="@box.ReSizable"
                                        ShowImage="@box.ShowImage"
                                        ImageSrc="@box.ImageSrc"
                                        LcdDisplay="@box.LcdDisplay"
                                        IsEnabled="@box.IsEnabled"
                                        ClickId="@box.ClickId"
                                        IsClickable="@box.IsClickable"
                                        OnClick="OnBoxClick"
                                        FooterClick="CloseBBoard">
                        <div class="lcd-wrapper">
                            <div class="lcd-display-outer" style="align-content:start">
                                <div class="bboard-item">
                                    @BboardHTML
                                </div>

                                
                            </div>
                        </div>

                                              
                                                  
                            </ContentBox>
                    }
             </div>
            }
    </PageContainer>
</LangGuard>











