@using KvizCommando.Client.Components.CharacterComponent

@if (_shouldBeShow)
{
    <div class="list-grid">
        @for (int i = 0; i < 5; i++)
        {
            <div>@vm.Rows[i].Label</div>
            <div class="left-value">@vm.Rows[i].Value</div>
            @if (Selected > 0)
            {
                <div></div>
                <div></div>
            }
            else
            {
                <div class="right-type">@vm.Rows[i + 5].Label</div>
                <div class="right-value">@vm.Rows[i + 5].Value</div>
            }
            
        }
    </div>
    <div class="picture-side @(string.IsNullOrEmpty(_picCode) ? "hide" : "")">
        <CharacterView PicCode="@_picCode" />
    </div>
    <hr class="separator">
}

