
@using KvizCommando.Client.Components.CharacterComponent

<div class="recruit-tab">
    @if (_couldBeHire)
    {
        @for (int i = 0; i < _vm.Cards.Count; i++)
        {

            @if (_vm.Cards[i].Show)
            {
                <RecruitCard CardNo="@(_vm.Cards[i].ClickId)"
                             Card="@(_vm.Cards[i].Card)"
                             SelectedCardNo="_selectedId"
                             Selected="OnCandidateSelect" />
            }
            else
            {
                <div></div>
            }
        }
        <div class="picture-block">
             <div class="picture-side">
                 @if(string.IsNullOrEmpty(_picCode))
                 {
                     <i class="bi bi-person" />
                 }
                 else
                 {
                    <CharacterView PicCode="@_picCode" />
                 }
                
                 
            </div>
            <div class="button-side">
                <button class="button-on-lcd" @onclick="OnHireButtonAsync" disabled="@(_selectedId==0)">
                    <i class="bi bi-person-fill-add"></i>
            </button>
            </div>
            
        </div>
       
    }
    else
    {
        <div class="hire-info">

        </div>    
    }
</div>

