@page "/team"

@using KvizCommando.Client.Pages.Team.Dynamic;
@inherits Utilities.KcComponentBase

<link href="css/team-common.css" rel="stylesheet" />

<LangGuard Culture=@Culture Module="team" OnReady="BuildBoxes">
  <PageContainer>
     
        @if (_isLoaded == true)
        {        
            <div class="kc-team-selector">
                @foreach (string bx in _boxOrder)
                {
                    var box = Box(bx);

                    <ContentBox Vm="@box"
                                OnClick="OnBoxClick">
                                <ContentBody>

                                    <CascadingValue Value="_selectedPos">
                                        <DynamicComponent Type="@box.BodyComponent"
                                                          Parameters="@box.BodyParameters" />         
                                    </CascadingValue>

                               </ContentBody>
                    </ContentBox>
                }
            </div>
        }

    </PageContainer>
</LangGuard>