@page "/team"

@using KvizCommando.Client.Data;
@using KvizCommando.Client.Pages.Team
@using KvizCommando.Client.Pages.Team.Components
@using KvizCommando.Client.Components.Dynamic;
@inherits Utilities.KcComponentBase

<link href="css/team-common.css" rel="stylesheet" />

<LangGuard Culture=@Culture Module="team" OnReady="BuildBoxes">
  <PageContainer>
        @if (_isLoaded == true)
        {
            <SubHeader id="_subHeader"
                       ActiveIndexChanged="OnSelectMember"
                        />
            <div class="kc-team-selector">
                @foreach (string bx in _boxOrder)
                {
                    var box = Box(bx);

                    <ContentBox Vm="@box"
                                OnClick="OnBoxClick">
                        <ContentBody>
                            <CascadingValue Value="_teamNav">
                              
                            </CascadingValue>
                        </ContentBody>
                    </ContentBox>
                }
            </div>
        }
    </PageContainer>
</LangGuard>