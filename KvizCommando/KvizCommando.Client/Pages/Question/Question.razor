@page "/question"
@inherits Utilities.KcComponentBase

@using KvizCommando.Client.Helpers
@using KvizCommando.Client.Pages.Question
@using KvizCommando.Client.Pages.Question.Components
<link href="css/question-common.css" rel="stylesheet" />

<LangGuard Culture=@_culture Module="question" OnReady="BuildBoxes">
        <PageContainer>
            @if (_isReady == true)
            {
                <div class="kc-quest-selector">
                    @foreach (string bx in _boxOrder)
                    {
                        var box = Box(bx);
                 
                        <ContentBox Vm="@box"
                                    OnClick="OnBoxClick">
                            
                            <ChildContent1>
                            <FactorySlotsBase ExtInfo="@_qState.ExtendedInfo"
                                              WorkingCodes="@_workingCodes"
                                              OriginalCodes="@_originalCodes"
                                              MessageFact="@MessageFact"
                                              isSuccess="@_isSuccess"
                                              SaveSlots="OnFactSaveAsync" />
                            </ChildContent1>
                            
                            <ChildContent2>
                            <UserSlotManager ExtInfo="@_qState.ExtendedInfo"
                                             Slots="@_qState.Userlots"
                                             NotShowDel="@_locNotShowStateDel"
                                             SelectedIdChanged="OnSelectId" />
                            </ChildContent2>

                            <ChildContent3>
                            <PendingSlotManager ExtInfo="@_qState.ExtendedInfo"
                                                Slots="@_qState.PendingSlots"
                                                HandleSlot="CallPendModal" />
                            </ChildContent3>
                            <ChildContent4>
                            <NewQuestionManager ExtInfo="@_qState.ExtendedInfo"
                                                MessageUsr="@MessageUsr"
                                                isSuccess="@_isSuccess"
                                                SendQuestion="SaveToForm" />
                            </ChildContent4>
                            <ChildContent5>
                                <button class="military-button"
                                        disabled="@(SelectedId == 100)"
                                        style="@_boxBtnStyle"
                                        @onclick="_onBoxBtnClick">
                                    @_boxBtnText
                                </button>
                            </ChildContent5>
                       
                        </ContentBox>
                
                    }
                </div>
            }










            @if (ScreenOption == 0)
            {
                <div class="quest-selector">
                    @foreach (var btn in _qbuttons!)
                    {
                        <ContentBox Header="@btn.Header"
                                    Footer="@btn.Footer"
                                    FooterDisplay="@btn.FooterDisplay"
                                    Size="@btn.Size"
                                    ShowImage="true"
                                    ImageSrc="@btn.ImageSrc"
                                    IsClickable="@btn.IsEnabled"
                                    IsEnabled="@btn.IsEnabled"
                                    ClickId="@btn.ClickId"
                                    OnClick="OnRootBtnClick" />
                    }
                </div>
            }
            else
            {
               
                <div class="box-container">
                   

                    <ContentBox Header=@BoxHeader 
                        Footer="" FooterDisplay=false 
                        Size="@(ScreenOption == 1 ? "halflarge" : "large")" 
                        Resizable="false">
                            <div class="lcd-wrapper">
                                @switch (ScreenOption)
                                {
                                    case 1:
                                        
                                        break;
                                    case 2:
                                       
                                        break;
                                    case 3:
                                       
                                        break;
                                    case 4:
                                       
                                        break;
                                    default:
                                        break;
                                }
                               
                            </div>
                       
                    </ContentBox>
                    
                </div>

            } 
        </PageContainer>
    
</LangGuard>



